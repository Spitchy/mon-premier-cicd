{
  "name": "mon-premier-cicd",
  "version": "1.0.0",
  "description": "Premier pipeline CI/CD avec GitHub Actions, Node.js, Jest et ESLint",
  "main": "src/calculator.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": ["cicd", "github-actions", "nodejs"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  }
}
